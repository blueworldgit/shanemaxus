// ============================================================
// 2. INJECT HERO + VEHICLE CAROUSEL via JavaScript
//    (places them inside #wrap after the header, before content)
// ============================================================
add_action( 'wp_footer', 'mvp_facelift_inject_hero_and_carousel', 1 );
function mvp_facelift_inject_hero_and_carousel() {
    if ( ! is_front_page() && ! is_home() ) return;

    $vehicles = array(
        array( 'name' => 'A80 Classic',        'years' => '2015-2023', 'abbr' => 'A80' ),
        array( 'name' => 'Deliver 3',           'years' => '2019-2023', 'abbr' => 'D3' ),
        array( 'name' => 'Deliver 7',           'years' => '2021-2023', 'abbr' => 'D7' ),
        array( 'name' => 'Deliver 7 Low Roof',  'years' => '2021-2023', 'abbr' => 'D7L' ),
        array( 'name' => 'Deliver 9',           'years' => '2020-2023', 'abbr' => 'D9' ),
        array( 'name' => 'E Deliver 3',         'years' => '2019-2023', 'abbr' => 'ED3' ),
        array( 'name' => 'E Deliver 9',         'years' => '2021-2023', 'abbr' => 'ED9' ),
        array( 'name' => 'Deliver 9 FRID',      'years' => '2023',     'abbr' => 'D9F' ),
        array( 'name' => 'T60',                 'years' => '2017-2023', 'abbr' => 'T60' ),
        array( 'name' => 'T90',                 'years' => '2023',     'abbr' => 'T90' ),
        array( 'name' => 'T90 EV',              'years' => '2023',     'abbr' => 'EV' ),
        array( 'name' => 'V80',                 'years' => '2014-2018', 'abbr' => 'V80' ),
    );

    // Build vehicle cards HTML
    $cards = '';
    foreach ( $vehicles as $v ) {
        $cards .= '<div class="mvp-vehicle-card">'
            . '<div class="mvp-vehicle-circle">' . esc_html( $v['abbr'] ) . '</div>'
            . '<div class="mvp-vehicle-name">' . esc_html( $v['name'] ) . '</div>'
            . '<div class="mvp-vehicle-years">' . esc_html( $v['years'] ) . '</div>'
            . '</div>';
    }

    $hero_html = '<div class="mvp-hero">'
        . '<div class="mvp-hero-content">'
        . '<h1>Genuine OEM Parts<br>Direct From Maxus</h1>'
        . '<p>Original factory parts at competitive prices. Perfect fit. Guaranteed quality.</p>'
        . '<a href="/shop/" class="mvp-hero-btn">Shop All Parts</a>'
        . '</div></div>';

    $carousel_html = '<section class="mvp-vehicles">'
        . '<div class="mvp-carousel-wrapper">'
        . '<button class="mvp-carousel-nav prev" onclick="document.querySelector(\'.mvp-carousel-track\').scrollBy({left:-220,behavior:\'smooth\'})">&#8249;</button>'
        . '<div class="mvp-carousel-track">' . $cards . '</div>'
        . '<button class="mvp-carousel-nav next" onclick="document.querySelector(\'.mvp-carousel-track\').scrollBy({left:220,behavior:\'smooth\'})">&#8250;</button>'
        . '</div></section>';

    $combined = json_encode( $hero_html . $carousel_html );
    ?>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var target = document.querySelector('.elementor-11641');
        if (!target) return;
        var container = document.createElement('div');
        container.id = 'mvp-facelift-hero-area';
        container.innerHTML = <?php echo $combined; ?>;
        target.parentNode.insertBefore(container, target);
    });
    </script>
    <?php
}

