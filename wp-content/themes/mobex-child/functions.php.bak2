    }
    .mvp-hero::after {
        content: '';
        position: absolute;
        right: 5%;
        bottom: 0;
        width: 420px;
        height: 200px;
        background: linear-gradient(to right, rgba(255,255,255,0.07), rgba(255,255,255,0.04));
        clip-path: polygon(5% 100%, 5% 40%, 15% 20%, 30% 15%, 35% 25%, 60% 25%, 65% 15%, 80% 15%, 90% 25%, 95% 40%, 95% 100%);
        pointer-events: none;
    }
    .mvp-hero-content {
        position: relative;
        z-index: 2;
        max-width: 700px;
        padding: 60px 40px;
        text-align: left;
    }
    .mvp-hero-content h1 {
        font-size: 42px;
        font-weight: 800;
        color: #fff;
        line-height: 1.15;
        margin: 0 0 18px;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-shadow: 0 2px 8px rgba(0,0,0,0.25);
